{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/infobucket-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Newsreader|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Newsreader, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AddButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClick|label|style|key|ref|className|style|children)$/]",
        "message": "<AddButton> doesn't accept that prop. Declared props: onClick, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BucketCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|count|description|sources|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BucketCard> doesn't accept that prop. Declared props: name, count, description, sources, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BucketChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|isNew|confirmed|onAccept|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BucketChip> doesn't accept that prop. Declared props: name, isNew, confirmed, onAccept, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|fullWidth|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, fullWidth, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, body, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ErrorBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|actionLabel|onAction|onDismiss|style|key|ref|className|style|children)$/]",
        "message": "<ErrorBanner> doesn't accept that prop. Declared props: message, actionLabel, onAction, onDismiss, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ItemCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|sourceName|title|summary|tags|status|proposedBucket|daysLeft|onAccept|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ItemCard> doesn't accept that prop. Declared props: source, sourceName, title, summary, tags, status, proposedBucket, daysLeft, onAccept, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|recording|onDictate|rows|style|key|ref|className|style|children)$/]",
        "message": "<NoteField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, recording, onDictate, rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onClear|placeholder|autoFocus|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: value, onChange, onClear, placeholder, autoFocus, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceStamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|size|showLabel|label|style|key|ref|className|style|children)$/]",
        "message": "<SourceStamp> doesn't accept that prop. Declared props: source, size, showLabel, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceStamp'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SourceStamp> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|dot|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, children, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute[name.name='key'] > Literal[value!=/^(?:inbox|library|search)$/]",
        "message": "<TabItem> key must be one of 'inbox' | 'library' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|removable|onRemove|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, removable, onRemove, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|hint|error|type|iconLeft|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, hint, error, type, iconLeft, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
