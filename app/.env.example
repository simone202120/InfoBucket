# Configurazione PUBBLICA del client Expo. Copia questo file in `app/.env`.
# Qui vivono SOLO valori non sensibili: URL del progetto e anon key (pubblica per design).
# Le chiavi AI e la service role NON vanno mai qui — stanno lato server (vedi supabase/.env.example).

# Dashboard Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
