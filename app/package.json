    "@supabase/supabase-js": "^2.45.0",
    "expo": "^54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-share-intent": "^5.1.1",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.460.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
