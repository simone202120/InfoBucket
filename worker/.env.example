# Worker InfoBucket — variabili d'ambiente.
# Copia questo file in worker/.env e compila i valori reali.
# I segreti vivono SOLO qui (env del servizio), MAI nel repo o nel client (spec §14).

# URL del progetto Supabase (es. https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key: scritture di pipeline lato server (bypassa RLS).
# MAI nel client Expo. Tienila segreta.
SUPABASE_SERVICE_ROLE_KEY=

# Chiave OpenAI: usata dal worker SOLO per la trascrizione Whisper (whisper-1).
# È la stessa chiave usata per gli embedding nelle Edge Functions: nessuna terza key (§4).
OPENAI_API_KEY=

# Intervallo di polling della coda media in millisecondi (default 5000).
POLL_INTERVAL_MS=5000
