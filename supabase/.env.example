# InfoBucket — segreti LATO SERVER (spec §14)
#
# ⚠️  Questi valori NON vanno MAI nel client Expo, MAI committati con valori reali.
#     Il client usa SOLO la `anon key` Supabase + l'auth dell'utente.
#     Vivono nei secrets delle Edge Functions e nell'env del worker.
#
# Copia in `.env` per lo sviluppo locale (supabase functions serve --env-file .env).
# In produzione: `supabase secrets set --env-file .env` (vedi README.md).

# --- Generazione AI (OpenRouter) --------------------------------------------
# Riassunto, tag, suggerimento bucket. Usata solo nelle Edge Functions.
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# Id del modello su OpenRouter. Cambiare modello = cambiare SOLO questa variabile.
# Default consigliato (economico, buon italiano, JSON affidabile, non-Anthropic).
# Verifica l'id corrente su openrouter.ai (gli id cambiano).
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Embedding + STT (OpenAI) -----------------------------------------------
# Stessa chiave per embedding (text-embedding-3-small → vector(1536)) e
# trascrizione audio del worker (whisper-1). Edge Functions + Worker.
OPENAI_API_KEY=sk-REPLACE_ME

# --- Supabase ----------------------------------------------------------------
# URL del progetto. Nelle Edge Functions Supabase è iniettata automaticamente;
# serve esplicita per il worker e per `functions serve` in locale.
SUPABASE_URL=https://REPLACE_ME.supabase.co
# Service role: BYPASSA le RLS → SOLO lato server (Edge Functions + Worker).
# Mai nel client. Nelle Edge Functions deployate è già disponibile come secret.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
